#!/usr/bin/env bash
#
# Hook pre-commit : lance le lint sur les fichiers staged.
# Bloque le commit si erreur.
#
# Pour activer :
#   ln -sf ../../scripts/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x scripts/hooks/pre-commit
#
# Pour bypasser exceptionnellement :
#   git commit --no-verify

set -e
cd "$(git rev-parse --show-toplevel)"

# Lint uniquement si des fichiers code sont staged
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(php|js|css|html|json)$' || true)

if [ -z "$STAGED" ]; then
    exit 0  # Rien à lint
fi

echo "→ Pre-commit lint sur les fichiers staged…"
./scripts/lint.sh --staged
